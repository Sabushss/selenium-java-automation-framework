<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    TestNG Suite Configuration
    Author: Subash A | QA Automation Engineer
    Supports: Parallel execution, grouping by smoke/regression
-->
<suite name="Selenium Automation Suite" parallel="methods" thread-count="3" verbose="1">

    <!-- Full Regression Suite -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.qa.tests.LoginTest"/>
            <class name="com.qa.tests.ProductsTest"/>
        </classes>
    </test>

    <!-- Smoke Suite only -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.qa.tests.LoginTest"/>
        </classes>
    </test>

</suite>
